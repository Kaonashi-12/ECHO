#!/bin/bash
#PBS -N echo-claim1-math
#PBS -q gpu_queue
#PBS -l select=1:ncpus=32:ngpus=4:mpiprocs=4:ompthreads=8:mem=300gb
#PBS -l walltime=00:30:00
#PBS -r n
#PBS -j oe
#PBS -o /oceanstor/home/e1553870/ECHO/outputs/pbs/echo-claim1-math.out
#PBS -e /oceanstor/home/e1553870/ECHO/outputs/pbs/echo-claim1-math.err

set -euo pipefail

ROOT="/oceanstor/home/e1553870/ECHO"
CONFIG="${CONFIG:-${ROOT}/configs/lm_eval_claim1_math_fast_qwen_v100.yaml}"
MODEL_NAME="${MODEL_NAME:-}"
TASKS="${TASKS:-}"
EXPORT_FIRST="${EXPORT_FIRST:-0}"
OVERWRITE_EXPORT="${OVERWRITE_EXPORT:-0}"
CONDA_BASE="${CONDA_BASE:-/home/svu/e1553870/miniconda3}"
CONDA_ENV="${CONDA_ENV:-s2i}"
NPROC_PER_NODE="${NPROC_PER_NODE:-4}"

mkdir -p "${ROOT}/outputs/pbs"
LOG_STDOUT="${ROOT}/outputs/pbs/echo-claim1-math-${PBS_JOBID:-$$}.out"
LOG_STDERR="${ROOT}/outputs/pbs/echo-claim1-math-${PBS_JOBID:-$$}.err"
exec >"${LOG_STDOUT}" 2>"${LOG_STDERR}"

cd "${ROOT}"

if [ -f "${CONDA_BASE}/etc/profile.d/conda.sh" ]; then
  . "${CONDA_BASE}/etc/profile.d/conda.sh"
else
  echo "[ERROR] conda.sh not found under ${CONDA_BASE}" >&2
  exit 2
fi
conda activate "${CONDA_ENV}"

export LD_LIBRARY_PATH="${CONDA_PREFIX:+${CONDA_PREFIX}/lib:}${LD_LIBRARY_PATH:-}"
export PYTHONUNBUFFERED=1
export PYTHONPATH="${ROOT}/src:${ROOT}/scripts:${PYTHONPATH:-}"
export HF_HOME="${HF_HOME:-/oceanstor/home/e1553870/.cache/huggingface}"
export TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE:-${HF_HOME}/transformers}"
export HF_DATASETS_CACHE="${HF_DATASETS_CACHE:-${HF_HOME}/datasets}"
export HF_DATASETS_OFFLINE="${HF_DATASETS_OFFLINE:-1}"
export HF_HUB_OFFLINE="${HF_HUB_OFFLINE:-1}"
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"
export OMP_NUM_THREADS="${OMP_NUM_THREADS:-8}"
export MKL_NUM_THREADS="${MKL_NUM_THREADS:-8}"
export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-8}"

mkdir -p "${HF_HOME}" "${HF_DATASETS_CACHE}"

echo "[INFO] host=$(hostname)"
echo "[INFO] root=${ROOT}"
echo "[INFO] config=${CONFIG}"
echo "[INFO] model_name=${MODEL_NAME:-<all>}"
echo "[INFO] tasks=${TASKS:-<config default>}"
echo "[INFO] export_first=${EXPORT_FIRST}"
echo "[INFO] CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
python - <<'PY'
import importlib.util
import os
import torch
expected = int(os.environ.get("NPROC_PER_NODE", "4"))
print("torch", torch.__version__, "cuda", torch.version.cuda, "available", torch.cuda.is_available())
print("device_count", torch.cuda.device_count())
if torch.cuda.device_count() < expected:
    raise SystemExit(f"Expected {expected} visible CUDA devices")
if importlib.util.find_spec("lm_eval") is None:
    raise SystemExit('lm_eval is not installed; run: pip install "lm_eval[hf]"')
PY
nvidia-smi

if [ "${EXPORT_FIRST}" = "1" ]; then
  EXPORT_ARGS=(--config "${CONFIG}")
  if [ -n "${MODEL_NAME}" ]; then
    EXPORT_ARGS+=(--model-name "${MODEL_NAME}")
  fi
  if [ "${OVERWRITE_EXPORT}" = "1" ]; then
    EXPORT_ARGS+=(--overwrite)
  fi
  python scripts/export_functional_lora_to_hf.py "${EXPORT_ARGS[@]}"
fi

EVAL_ARGS=(--config "${CONFIG}" --num-processes "${NPROC_PER_NODE}")
if [ -n "${MODEL_NAME}" ]; then
  EVAL_ARGS+=(--model-name "${MODEL_NAME}")
fi
if [ -n "${TASKS}" ]; then
  EVAL_ARGS+=(--tasks "${TASKS}")
fi

python scripts/run_lm_eval_official.py "${EVAL_ARGS[@]}"
